# Without a .env file, Compose automatically uses ./config.
# Unraid:
CONFIG_PATH=/mnt/user/appdata/subscription-reminder

# Other Linux servers, for example:
# CONFIG_PATH=/opt/subscription-reminder

TZ=Europe/Berlin

# Unraid default: nobody/users. Most regular Linux servers use 1000/1000.
PUID=99
PGID=100
