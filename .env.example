# Ohne .env wird automatisch ./config verwendet.
# Unraid:
CONFIG_PATH=/mnt/user/appdata/subscription-reminder

# Andere Linux-Server, zum Beispiel:
# CONFIG_PATH=/opt/subscription-reminder

TZ=Europe/Berlin

# Unraid-Standard: nobody/users. Auf üblichen Linux-Servern oft 1000/1000.
PUID=99
PGID=100
